#!/usr/bin/env bash
# gh-dev-aid — GitHub CLI extension for Dev-AID
# Install: gh extension install Probably-Group/gh-dev-aid
# Usage:   gh dev-aid <command> [args]

set -euo pipefail
IFS=$'\n\t'

readonly EXTENSION_VERSION="1.2.0"
readonly REPO="Probably-Group/Dev-AID"

# Protected paths — never overwritten or deleted during update
# These contain project-specific data, user credentials, or expensive-to-rebuild artifacts
readonly -a PROTECTED_PATHS=(
    # User credentials & config
    "config/.env"
    "config/.env.*"
    "config/settings.json"
    "config/core-skills.local.json"
    # Project knowledge
    "memory-bank/"
    "logs/"
    # Expensive to rebuild (venvs, RAG indices)
    "orchestration/venv/"
    "local-search/venv/"
    "local-search/index/"
    "deep-research/venv/"
    # Temp/cache (harmless to keep)
    "temp/"
    # User backups
    "backups/"
)

# --- Cleanup ---

TEMP_DIR=""
cleanup() {
    rm -rf -- "${TEMP_DIR:-}"
}
trap cleanup EXIT

# --- Helpers ---

die() {
    echo "error: $*" >&2
    exit 1
}

info() {
    echo ":: $*"
}

warn() {
    echo "!! $*" >&2
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not found"
}

find_dev_aid() {
    if [[ -d ".dev-aid" ]]; then
        echo "."
    else
        die ".dev-aid/ not found in current directory. Run 'gh dev-aid init' first."
    fi
}

get_local_version() {
    if [[ -f ".dev-aid/VERSION" ]]; then
        tr -d '[:space:]' < .dev-aid/VERSION
    else
        echo "unknown"
    fi
}

get_remote_version() {
    local tmpdir="$1"
    if [[ -f "${tmpdir}/Dev-AID/.dev-aid/VERSION" ]]; then
        tr -d '[:space:]' < "${tmpdir}/Dev-AID/.dev-aid/VERSION"
    else
        echo "unknown"
    fi
}

# --- Commands ---

cmd_init() {
    local target_path="${1:-.}"
    target_path="$(cd "${target_path}" && pwd)"

    if [[ -d "${target_path}/.dev-aid" ]]; then
        die ".dev-aid/ already exists in ${target_path}. Use 'gh dev-aid update' instead."
    fi

    need_cmd gh

    TEMP_DIR="$(mktemp -d)"

    info "Cloning Dev-AID..."
    gh repo clone "${REPO}" "${TEMP_DIR}/Dev-AID" -- --depth 1 --quiet

    info "Copying .dev-aid/ to ${target_path}..."
    cp -r "${TEMP_DIR}/Dev-AID/.dev-aid" "${target_path}/.dev-aid"

    info "Initializing Dev-AID..."
    (cd "${target_path}" && ./.dev-aid/scripts/init-repo.sh)

    info "Done! Dev-AID is ready in ${target_path}"
    echo ""
    echo "Next steps:"
    echo "  cd ${target_path}"
    echo "  claude    # or gemini, cursor, windsurf, etc."
    echo "  /aid-help # see all available commands"
}

cmd_update() {
    find_dev_aid >/dev/null
    need_cmd gh
    need_cmd rsync

    local local_version
    local_version="$(get_local_version)"
    info "Current version: ${local_version}"

    # Clone latest
    TEMP_DIR="$(mktemp -d)"

    info "Fetching latest Dev-AID..."
    gh repo clone "${REPO}" "${TEMP_DIR}/Dev-AID" -- --depth 1 --quiet

    local remote_version
    remote_version="$(get_remote_version "${TEMP_DIR}")"
    info "Latest version:  ${remote_version}"

    if [[ "${local_version}" == "${remote_version}" ]] && [[ "${local_version}" != "unknown" ]]; then
        echo ""
        echo "Already up to date (${local_version})."
        return 0
    fi

    # Create backup
    local backup_dir
    backup_dir=".dev-aid-backup-$(date +%Y%m%d-%H%M%S)"
    info "Creating backup at ${backup_dir}..."
    cp -r .dev-aid "${backup_dir}"

    # Build rsync exclude list for protected paths
    local exclude_args=()
    for path in "${PROTECTED_PATHS[@]}"; do
        exclude_args+=(--exclude "${path}")
    done

    # Apply update
    info "Updating .dev-aid/ (${local_version} -> ${remote_version})..."
    rsync -a --delete "${exclude_args[@]}" "${TEMP_DIR}/Dev-AID/.dev-aid/" ".dev-aid/"

    echo ""
    echo "Updated: ${local_version} -> ${remote_version}"
    echo "Backup:  ${backup_dir}"
    echo ""
    echo "To rollback: rm -rf .dev-aid && mv ${backup_dir} .dev-aid"

    # Cleanup old backups (keep last 3)
    # Glob sorts alphabetically, which is chronological for YYYYMMDD-HHMMSS names
    local -a old_backups=()
    for d in .dev-aid-backup-*; do
        [[ -d "${d}" ]] && old_backups+=("${d}")
    done
    local total="${#old_backups[@]}"
    if [[ "${total}" -gt 3 ]]; then
        local i
        for ((i = 0; i <= total - 4; i++)); do
            info "Removing old backup: ${old_backups[i]}"
            rm -rf -- "${old_backups[i]}"
        done
    fi
}

cmd_check() {
    need_cmd gh

    local local_version="unknown"
    if [[ -f ".dev-aid/VERSION" ]]; then
        local_version="$(get_local_version)"
    fi

    # Fetch remote VERSION file without cloning the whole repo
    local remote_version
    remote_version="$(gh api "repos/${REPO}/contents/.dev-aid/VERSION" --jq '.content' 2>/dev/null | base64 -d | tr -d '[:space:]')" || remote_version="unknown"

    echo "Installed: ${local_version}"
    echo "Latest:    ${remote_version}"

    if [[ "${local_version}" == "unknown" ]]; then
        echo ""
        echo "Dev-AID not found. Run: gh dev-aid init"
        return 1
    elif [[ "${remote_version}" == "unknown" ]]; then
        warn "Could not fetch latest version"
        return 1
    elif [[ "${local_version}" != "${remote_version}" ]]; then
        echo ""
        echo "Update available! Run: gh dev-aid update"
        return 0
    else
        echo ""
        echo "Up to date."
        return 0
    fi
}

cmd_status() {
    find_dev_aid >/dev/null

    echo "Dev-AID version: $(get_local_version)"

    if [[ -x ".dev-aid/scripts/dev-aid-health.sh" ]]; then
        echo ""
        ./.dev-aid/scripts/dev-aid-health.sh
    fi
}

cmd_version() {
    echo "gh-dev-aid extension: v${EXTENSION_VERSION}"

    if [[ -f ".dev-aid/VERSION" ]]; then
        echo "Dev-AID installed:    v$(get_local_version)"
    else
        echo "Dev-AID installed:    not found (run 'gh dev-aid init')"
    fi

    echo ""
    echo "Extension update:  gh extension upgrade gh-dev-aid"
    echo "Dev-AID update:    gh dev-aid update"
}

cmd_help() {
    cat <<EOF
gh dev-aid — GitHub CLI extension for Dev-AID

Usage:
  gh dev-aid <command> [args]

Commands:
  init [path]   Install Dev-AID into a project directory (default: current dir)
  update        Update Dev-AID to the latest version
  check         Check if a newer version is available
  status        Show version and health check
  version       Show extension and Dev-AID versions
  help          Show this help message

Examples:
  gh dev-aid init                  # Install in current directory
  gh dev-aid init ~/my-project     # Install in specific directory
  gh dev-aid update                # Update to latest version
  gh dev-aid check                 # Check for updates (no changes)
  gh dev-aid status                # Check health

Update the extension itself:
  gh extension upgrade gh-dev-aid

More info: https://github.com/Probably-Group/Dev-AID
EOF
}

# --- Main ---

case "${1:-help}" in
    init)    shift; cmd_init "$@" ;;
    update)  shift; cmd_update "$@" ;;
    check)   cmd_check ;;
    status)  cmd_status ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)       die "Unknown command: $1. Run 'gh dev-aid help' for usage." ;;
esac
